+
 #include "../wsi_window.h"
 
 #include "native/wsi/native_sdl3.h"
@@ -168,8 +175,44 @@ namespace dxvk::wsi {
           VkSurfaceKHR*             pSurface) {
     SDL_Window* window = fromHwnd(hWindow);
 
+#if defined(__ANDROID__)
+    // GeneralsX @android FadiLabib 07/07/2026 - Create the surface via DXVK's OWN
+    // Vulkan loader (Turnip through adrenotools), NOT SDL_Vulkan_CreateSurface.
+    // SDL loaded a SEPARATE, stock libvulkan (SDL_Vulkan_LoadLibrary in
+    // getInstanceExtensions); handing our Turnip-loader VkInstance to SDL's stock
+    // loader mismatches the instance dispatch and fails with
+    // VK_ERROR_OUT_OF_HOST_MEMORY. vkCreateAndroidSurfaceKHR is a loader/WSI entry,
+    // so resolving it from the same loader that owns `instance` keeps everything in
+    // one loader. We only need the ANativeWindow* from SDL (a plain handle).
+    SDL_PropertiesID props = SDL_GetWindowProperties(window);
+    if (props == 0) {
+      Logger::err("SDL3 WSI (Android): SDL_GetWindowProperties failed");
+      return VK_ERROR_OUT_OF_HOST_MEMORY;
+    }
+    // SDL_PROP_WINDOW_ANDROID_WINDOW_POINTER == "SDL.window.android.window".
+    void* nativeWindow = SDL_GetPointerProperty(props, "SDL.window.android.window", nullptr);
+    if (nativeWindow == nullptr) {
+      Logger::err("SDL3 WSI (Android): no ANativeWindow on SDL window");
+      return VK_ERROR_OUT_OF_HOST_MEMORY;
+    }
+
+    auto pfnCreateAndroidSurface = reinterpret_cast<PFN_vkCreateAndroidSurfaceKHR>(
+      pfnVkGetInstanceProcAddr(instance, "vkCreateAndroidSurfaceKHR"));
+    if (pfnCreateAndroidSurface == nullptr) {
+      Logger::err("SDL3 WSI (Android): vkCreateAndroidSurfaceKHR not found in the DXVK Vulkan loader");
+      return VK_ERROR_EXTENSION_NOT_PRESENT;
+    }
+
+    VkAndroidSurfaceCreateInfoKHR surfaceInfo = { VK_STRUCTURE_TYPE_ANDROID_SURFACE_CREATE_INFO_KHR };
+    surfaceInfo.window = reinterpret_cast<ANativeWindow*>(nativeWindow);
+    VkResult vr = pfnCreateAndroidSurface(instance, &surfaceInfo, nullptr, pSurface);
+    if (vr != VK_SUCCESS)
+      Logger::err(str::format("SDL3 WSI (Android): vkCreateAndroidSurfaceKHR failed: ", vr));
+    return vr;
+#else
     return SDL_Vulkan_CreateSurface(window, instance, nullptr, pSurface)
       ? VK_SUCCESS : VK_ERROR_OUT_OF_HOST_MEMORY;
+#endif
   }
 
