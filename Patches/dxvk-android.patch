diff --git a/src/vulkan/vulkan_loader.cpp b/src/vulkan/vulkan_loader.cpp
index 518efcb1..3ca3e70f 100644
--- a/src/vulkan/vulkan_loader.cpp
+++ b/src/vulkan/vulkan_loader.cpp
@@ -7,9 +7,85 @@
 #include "../util/util_string.h"
 #include "../util/util_win32_compat.h"
 
+#if defined(__ANDROID__)
+// GeneralsX @android FadiLabib 07/07/2026 - Turnip-via-adrenotools loader.
+// The stock Qualcomm driver on the Adreno 650 only reports Vulkan 1.1, which
+// DXVK 2.6 rejects ("Skipping Vulkan 1.1 adapter" -> "No adapters found"). We
+// instead load a bundled Mesa Turnip driver (Vulkan 1.3+) through libadrenotools,
+// which hooks the Android linker namespace so libvulkan.so opens Turnip instead of
+// the vendor driver. adrenotools is dlopen'd (not linked) to keep the meson build
+// untouched; the app (SDL3Main.cpp) sets the three env vars below before we run.
+#include <cstdlib>
+#include <dlfcn.h>
+
+namespace {
+  // Mirror of adrenotools/priv.h ADRENOTOOLS_DRIVER_CUSTOM (bit 0). Redeclared here
+  // so DXVK needs no adrenotools headers at compile time.
+  constexpr int kAdrenotoolsDriverCustom = 1 << 0;
+  using PFN_adrenotools_open_libvulkan = void* (*)(
+    int dlopenMode, int featureFlags, const char* tmpLibDir, const char* hookLibDir,
+    const char* customDriverDir, const char* customDriverName, const char* fileRedirectDir,
+    void** userMappingHandle);
+
+  // Returns a handle to a libvulkan routed into the bundled Turnip driver, or
+  // nullptr if the env is not configured / adrenotools fails (caller falls back
+  // to the stock libvulkan.so). hookLibDir MUST be the APK nativeLibraryDir (holds
+  // libhook_impl.so / libmain_hook.so); customDriverDir MUST be a private, non-sdcard
+  // dir (the app's internal files dir) holding the copied Turnip .so.
+  void* dxvkAndroidOpenTurnip() {
+    const char* hookLibDir     = std::getenv("GENERALSX_ADRENOTOOLS_HOOK_DIR");
+    const char* customDriverDir  = std::getenv("GENERALSX_TURNIP_DRIVER_DIR");
+    const char* customDriverName = std::getenv("GENERALSX_TURNIP_DRIVER_NAME");
+    if (!hookLibDir || !customDriverDir || !customDriverName) {
+      dxvk::Logger::warn("Vulkan: adrenotools env not set (GENERALSX_ADRENOTOOLS_HOOK_DIR/"
+                         "GENERALSX_TURNIP_DRIVER_DIR/GENERALSX_TURNIP_DRIVER_NAME); using stock libvulkan.so");
+      return nullptr;
+    }
+
+    void* adreno = dlopen("libadrenotools.so", RTLD_NOW | RTLD_LOCAL);
+    if (!adreno) {
+      dxvk::Logger::warn(dxvk::str::format("Vulkan: dlopen(libadrenotools.so) failed: ", dlerror()));
+      return nullptr;
+    }
+
+    auto openLibvulkan = reinterpret_cast<PFN_adrenotools_open_libvulkan>(
+      dlsym(adreno, "adrenotools_open_libvulkan"));
+    if (!openLibvulkan) {
+      dxvk::Logger::warn("Vulkan: adrenotools_open_libvulkan not found in libadrenotools.so");
+      return nullptr;
+    }
+
+    dxvk::Logger::info(dxvk::str::format("Vulkan: opening Turnip via adrenotools (hookLibDir=", hookLibDir,
+                                         " driverDir=", customDriverDir, " driver=", customDriverName, ")"));
+    void* handle = openLibvulkan(RTLD_NOW | RTLD_LOCAL, kAdrenotoolsDriverCustom,
+                                 nullptr /*tmpLibDir (memfd on API>=29)*/, hookLibDir,
+                                 customDriverDir, customDriverName, nullptr /*fileRedirectDir*/,
+                                 nullptr /*userMappingHandle*/);
+    if (!handle)
+      dxvk::Logger::warn("Vulkan: adrenotools_open_libvulkan returned null (Turnip not loaded); using stock libvulkan.so");
+    return handle;
+  }
+}
+#endif
+
 namespace dxvk::vk {
 
   static std::pair<HMODULE, PFN_vkGetInstanceProcAddr> loadVulkanLibrary() {
+#if defined(__ANDROID__)
+    // GeneralsX @android FadiLabib 07/07/2026 - Prefer the bundled Turnip driver
+    // (Vulkan 1.3) via adrenotools. Falls through to the stock libvulkan.so list
+    // below if the driver package or hooks are missing / adrenotools fails.
+    if (HMODULE turnip = reinterpret_cast<HMODULE>(dxvkAndroidOpenTurnip())) {
+      auto proc = GetProcAddress(turnip, "vkGetInstanceProcAddr");
+      if (proc) {
+        Logger::info(str::format("Vulkan: Found vkGetInstanceProcAddr in adrenotools/Turnip libvulkan @ 0x",
+                                 std::hex, reinterpret_cast<uintptr_t>(proc)));
+        return std::make_pair(turnip, reinterpret_cast<PFN_vkGetInstanceProcAddr>(proc));
+      }
+      Logger::warn("Vulkan: adrenotools handle has no vkGetInstanceProcAddr; falling back to stock libvulkan.so");
+      FreeLibrary(turnip);
+    }
+#endif
 #ifdef _WIN32
     static const std::array<const char*, 2> dllNames = {{
       "winevulkan.dll",
