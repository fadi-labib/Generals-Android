@@ -1,5 +1,12 @@
 #if defined(DXVK_WSI_SDL3)
 
+// GeneralsX @android FadiLabib 07/07/2026 - Pull in VkAndroidSurfaceCreateInfoKHR /
+// PFN_vkCreateAndroidSurfaceKHR. MUST precede any <vulkan/vulkan.h> include so the
+// Android WSI platform types are declared (createSurface uses them below).
+#if defined(__ANDROID__)
