# Meson cross file: build DXVK for Android (arm64-v8a, API 29) on a Linux host.
# Android analog of meson-arm64-ios-cross.ini.in. Instead of xcrun + an SDK
# sysroot, it drives the NDK's per-API clang wrappers directly: the
# aarch64-linux-android29-clang / clang++ wrappers already embed
# -target aarch64-linux-android29 and --sysroot, so no arch/sysroot flags are
# needed in [built-in options].
#
# @ANDROID_NDK_BIN@ -> $ANDROID_NDK_HOME/toolchains/llvm/prebuilt/<host>/bin
# @GLSLANG@         -> a host glslang/glslangValidator (runs on the build machine;
#                      compiles DXVK's shaders to SPIR-V at build time).
#
# SDL3 for Android must be discoverable via PKG_CONFIG_PATH (an sdl3.pc pointing
# at the FetchContent SDL3 build: build/<preset>/_deps/sdl3-build + sdl3-src/include),
# mirroring the iOS/macOS SDL3 pkg-config generated by cmake/dx8.cmake. Without it
# meson silently falls back to SDL2 and compiles the WSI as Sdl2WsiDriver.

[binaries]
c = '@ANDROID_NDK_BIN@/aarch64-linux-android29-clang'
cpp = '@ANDROID_NDK_BIN@/aarch64-linux-android29-clang++'
ar = '@ANDROID_NDK_BIN@/llvm-ar'
strip = '@ANDROID_NDK_BIN@/llvm-strip'
pkg-config = 'pkg-config'
glslang = '@GLSLANG@'

[host_machine]
system = 'android'
cpu_family = 'aarch64'
cpu = 'aarch64'
endian = 'little'

[built-in options]
c_args = []
cpp_args = []
c_link_args = []
cpp_link_args = []
